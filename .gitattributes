# Auto-detect text files and normalize to LF
* text=auto

# Python
*.py text diff=python
*.pyw text
*.toml text
*.yaml text
*.yml text
*.json text
*.cfg text
*.ini text

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# Docker
Dockerfile text
docker-compose.yml text
.dockerignore text

# Docs
*.md text
*.txt text

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pkl binary
*.db binary
