# ============================================
# 环境变量示例 .env.example
# ============================================
# 复制为 .env 并填入真实密钥；.env 已在 .gitignore 中。
# 程序在启动时自动读取（config/alerts.yaml 中敏感字段留空即会从环境变量读取）。
# ============================================

# -------- 告警推送通道密钥 --------

# Server 酱（ftqq.com）：SCT... 前缀
# 注册地址：https://sct.ftqq.com/
SERVERCHAN_KEY="SCT338797TIlwvsr54Rs5Y976vO5u0si1G"

# Bark（iOS APP）设备 Key
# APP 首页可见，形如 XxxxxxxxxxxxxxxxXxxxx
BARK_KEY=

# PushPlus（推送加）：32 位字符 token
# 注册地址：http://www.pushplus.plus/
PUSHPLUS_TOKEN=


# -------- 可选：数据库 --------
# 启用 storage 模块时使用，SQLite 可忽略
DATABASE_URL=sqlite:///./cache/stock_analyze.db


# -------- 可选：日志级别 --------
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
